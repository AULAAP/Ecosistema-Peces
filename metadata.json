
import React, { useState, useRef } from 'react';
import type { WeeklyPlan, Church, Cluster } from './types';
import TopicCard from './components/TopicCard';
import MonitoringPanel from './components/MonitoringPanel';
import ChurchesPanel from './components/ChurchesPanel';
import ClustersPanel from './components/ClustersPanel';
import DashboardPanel from './components/DashboardPanel';
import ArrowLeftIcon from './components/icons/ArrowLeftIcon';
import UploadIcon from './components/icons/UploadIcon';
import Loader from './components/Loader';
import { weeklyPlanData as initialWeeklyPlan, churchesData as initialChurches, clustersData as initialClusters } from './data';
import { extractTopicsFromDocument, getYouTubeRecommendation } from './services/geminiService';
import useLocalStorage from './hooks/useLocalStorage';
import AnimatedBackground from './components/AnimatedBackground';
import { jsPDF } from 'jspdf';
import html2canvas from 'html2canvas';
import DownloadIcon from './components/icons/DownloadIcon';

type ActiveTab = 'clusters' | 'churches' | 'progress' | 'plan' | 'dashboard';
type ProgressData = Record<number, Record<number, boolean>>;

interface AppState {
  clusterId: number | null;
  churchId: number | null;
  tab: ActiveTab;
}

const App: React.FC = () => {
  const [plans, setPlans] = useLocalStorage<WeeklyPlan[]>('ministerialWeeklyPlans_v10_final', initialWeeklyPlan.map(p => ({ ...p, isCompleted: false })));
  const [selectedMonth, setSelectedMonth] = useState<number | null>(null);

  // Efecto para forzar la sincronización si detectamos datos antiguos o incoherentes
  React.useEffect(() => {
    const isDataIncoherent = plans.length > 0 && (
      plans.length !== initialWeeklyPlan.length ||
      plans[0].topic !== initialWeeklyPlan[0].topic || 
      (plans[1] && plans[1].topic !== initialWeeklyPlan[1].topic)
    );
    
    if (isDataIncoherent) {
      setPlans(initialWeeklyPlan.map(p => ({ ...p, isCompleted: false })));
    }
  }, [plans, setPlans]);

  const handleManualReset = () => {
    if (window.confirm("¿Estás seguro de que deseas reiniciar todo el plan de estudio? Esto borrará tu progreso actual.")) {
        setPlans(initialWeeklyPlan.map(p => ({ ...p, isCompleted: false })));
        setChurchProgressData({});
        setClusterProgressData({});
        alert("Plan reiniciado con éxito.");
    }
  };
  const [isProcessingDoc, setIsProcessingDoc] = useState(false);
  const [loadingMsg, setLoadingMsg] = useState('');
  const fileInputRef = useRef<HTMLInputElement>(null);

  const [clusters, setClusters] = useLocalStorage<Cluster[]>('clustersData', initialClusters);
  const [churches, setChurches] = useLocalStorage<Church[]>('churchesData', initialChurches);
  
  const [churchProgressData, setChurchProgressData] = useLocalStorage<ProgressData>('trainingProgress', {});
  const [clusterProgressData, setClusterProgressData] = useLocalStorage<ProgressData>('clusterTrainingProgress', {});
  
  const [appState, setAppState] = useLocalStorage<AppState>('appState', {
    clusterId: null,
    churchId: null,
    tab: 'clusters',
  });

  const { clusterId, churchId, tab: activeTab } = appState;
  const selectedCluster = clusters.find(c => c.id === clusterId) || null;
  const selectedChurch = churches.find(c => c.id === churchId) || null;
  
  const currentViewPlans = React.useMemo(() => {
    if (!selectedChurch && !selectedCluster) return [];
    let progress = selectedChurch ? (churchProgressData[selectedChurch.id] || {}) : (clusterProgressData[selectedCluster!.id] || {});
    return plans.map(plan => ({
      ...plan,
      isCompleted: progress[plan.weekNumber] === true,
    }));
  }, [plans, selectedChurch, selectedCluster, churchProgressData, clusterProgressData]);

  // --- FUNCIONES DE REINICIO DE PROGRESO ---
  
  const handleResetChurchProgress = (id: number) => {
    setChurchProgressData(prev => {
      const next = { ...prev };
      next[id] = {}; // Setea el progreso de esta iglesia específica a un objeto vacío
      return next;
    });
  };

  const handleResetClusterProgress = (id: number) => {
    const cluster = clusters.find(c => c.id === id);
    if (!cluster) return;

    // 1. Reiniciar progreso del clúster
    setClusterProgressData(prev => ({
      ...prev,
      [id]: {}
    }));

    // 2. Reiniciar progreso de todas las iglesias de ese clúster
    setChurchProgressData(prev => {
      const next = { ...prev };
      cluster.churchIds.forEach(cid => {
        next[cid] = {};
      });
      return next;
    });
  };

  // --- MANEJO DE ARCHIVOS Y TOGGLE ---

  const handleFileUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;

    setIsProcessingDoc(true);
    setLoadingMsg('Analizando Misión y Visión con Inteligencia Artificial...');

    try {
        const text = await file.text();
        if (text.length < 50) throw new Error("El documento es demasiado corto.");
        
        const extractedTopics = await extractTopicsFromDocument(text);
        const newPlans: WeeklyPlan[] = [];

        for (let i = 0; i < extractedTopics.length; i++) {
            setLoadingMsg(`Buscando recursos multimedia para: "${extractedTopics[i].topic}" (${i + 1}/${extractedTopics.length})`);
            const recommendation = await getYouTubeRecommendation(extractedTopics[i].topic);
            newPlans.push({
                weekNumber: i + 1,
                topic: extractedTopics[i].topic,
                ...recommendation,
                isCompleted: false
            });
        }
        
        setPlans(newPlans);
        alert("¡Plan personalizado generado con éxito!");
    } catch (error) {
        console.error(error);
        alert("Error al procesar el documento. Intenta de nuevo.");
    } finally {
        setIsProcessingDoc(false);
        if (fileInputRef.current) fileInputRef.current.value = '';
    }
  };

  const handleToggleComplete = (weekNumber: number) => {
    if (selectedChurch) {
        setChurchProgressData(prev => ({
            ...prev,
            [selectedChurch.id]: { ...(prev[selectedChurch.id] || {}), [weekNumber]: !(prev[selectedChurch.id]?.[weekNumber]) }
        }));
    } else if (selectedCluster) {
        const newState = !(clusterProgressData[selectedCluster.id]?.[weekNumber]);
        setClusterProgressData(prev => ({ ...prev, [selectedCluster.id]: { ...(prev[selectedCluster.id] || {}), [weekNumber]: newState } }));
        setChurchProgressData(prev => {
            const next = { ...prev };
            selectedCluster.churchIds.forEach(id => {
                next[id] = { ...(next[id] || {}), [weekNumber]: newState };
            });
            return next;
        });
    }
  };

  const generateCertificate = async (month: number, monthPlans: WeeklyPlan[]) => {
    const entityName = selectedChurch?.name || selectedCluster?.name || 'Líder Ministerial';
    const moduleTitle = getModuleTitle(monthPlans);
    
    // Crear un elemento temporal para el certificado
    const certElement = document.createElement('div');
    certElement.style.width = '800px';
    certElement.style.height = '600px';
    certElement.style.padding = '40px';
    certElement.style.background = 'linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%)';
    certElement.style.border = '20px solid #4f46e5';
    certElement.style.display = 'flex';
    certElement.style.flexDirection = 'column';
    certElement.style.alignItems = 'center';
    certElement.style.justifyContent = 'center';
    certElement.style.textAlign = 'center';
    certElement.style.fontFamily = 'sans-serif';
    certElement.style.position = 'fixed';
    certElement.style.left = '-9999px';
    certElement.style.top = '0';

    certElement.innerHTML = `
      <div style="border: 2px solid #4f46e5; padding: 40px; width: 100%; height: 100%; box-sizing: border-box; display: flex; flexDirection: column; align-items: center; justify-content: center; background: white;">
        <h1 style="color: #1e1b4b; font-size: 48px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 4px;">Certificado de Logro</h1>
        <p style="color: #64748b; font-size: 18px; margin-bottom: 40px;">Otorgado a:</p>
        <h2 style="color: #4f46e5; font-size: 36px; margin-bottom: 10px; border-bottom: 2px solid #e2e8f0; padding-bottom: 10px; width: 80%;">${entityName}</h2>
        <p style="color: #64748b; font-size: 18px; margin-top: 30px;">Por completar satisfactoriamente el módulo:</p>
        <h3 style="color: #1e1b4b; font-size: 24px; font-weight: bold; margin-top: 10px;">${moduleTitle}</h3>
        <p style="color: #94a3b8; font-size: 14px; margin-top: 50px;">Ecosistema PECES - Plataforma de Liderazgo Ministerial</p>
        <div style="margin-top: 40px; width: 100%; display: flex; justify-content: space-around;">
          <div style="border-top: 1px solid #cbd5e1; width: 200px; padding-top: 10px; font-size: 12px; color: #64748b;">Firma del Mentor</div>
          <div style="border-top: 1px solid #cbd5e1; width: 200px; padding-top: 10px; font-size: 12px; color: #64748b;">Fecha: ${new Date().toLocaleDateString()}</div>
        </div>
      </div>
    `;

    document.body.appendChild(certElement);

    try {
      const canvas = await html2canvas(certElement, { scale: 2 });
      const imgData = canvas.toDataURL('image/png');
      const pdf = new jsPDF('l', 'px', [800, 600]);
      pdf.addImage(imgData, 'PNG', 0, 0, 800, 600);
      pdf.save(`Certificado_${entityName.replace(/\s+/g, '_')}_Mes_${month}.pdf`);
    } catch (err) {
      console.error('Error generating PDF:', err);
      alert('Hubo un error al generar el certificado.');
    } finally {
      document.body.removeChild(certElement);
    }
  };

  const getModuleTitle = (monthPlans: WeeklyPlan[]) => {
    if (!monthPlans.length) return "Módulo de Capacitación";
    const topics = monthPlans.map(p => p.topic);
    
    // Extraer palabras clave significativas (más de 4 letras, capitalizadas)
    const keywords = topics.join(' ').split(' ')
      .map(w => w.replace(/[,.]/g, ''))
      .filter(w => w.length > 4 && !['sobre', 'entre', 'desde', 'hacia', 'hasta'].includes(w.toLowerCase()))
      .map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase());
    
    // Tomar las 2 más relevantes
    const uniqueKeywords = Array.from(new Set(keywords)).slice(0, 2);
    
    // Prefijos llamativos según el número de semana inicial del mes
    const prefixes = [
      "Impacto Ministerial",
      "Dominio Estratégico",
      "Excelencia en Liderazgo",
      "Poder y Visión",
      "Ruta de Crecimiento",
      "Maestría en Servicio",
      "Fundamentos de Gloria",
      "Vanguardia Espiritual"
    ];
    
    const prefixIndex = Math.floor((monthPlans[0].weekNumber - 1) / 4) % prefixes.length;
    const prefix = prefixes[prefixIndex];
    
    // Títulos específicos para los módulos por defecto si coinciden con los temas sistemáticos
    if (monthPlans[0].weekNumber === 1) return "Fundamentos y Bienvenida";
    if (monthPlans[0].weekNumber === 5) return "Recursos y Organización";
    if (monthPlans[0].weekNumber === 9) return "Despertar y Acción";
    if (monthPlans[0].weekNumber === 13) return "El Mundo de Abby y Liderazgo";
    if (monthPlans[0].weekNumber === 17) return "Equipamiento y Vocación";
    if (monthPlans[0].weekNumber === 21) return "Retención y Cuidado";
    if (monthPlans[0].weekNumber === 25) return "Gestión y Control del Aula";
    if (monthPlans[0].weekNumber === 29) return "Pedagogía y Dinámicas";
    if (monthPlans[0].weekNumber === 33) return "Evaluación y Herramientas";

    return uniqueKeywords.length > 0 
      ? `${prefix}: ${uniqueKeywords.join(' & ')}` 
      : `${prefix} para el Reino`;
  };

  const renderContent = () => {
    if (isProcessingDoc) return <div className="mt-20 flex flex-col items-center"><Loader message={loadingMsg} /></div>;

    switch (activeTab) {
      case 'clusters':
        return (
          <ClustersPanel 
            clusters={clusters} 
            selectedClusterId={selectedCluster?.id} 
            onSelectCluster={(c) => setAppState({ clusterId: c.id, churchId: null, tab: 'churches' })} 
            onAddCluster={(name) => setClusters([...clusters, { id: Date.now(), name, churchIds: [] }])} 
            onDeleteCluster={(id) => setClusters(clusters.filter(c => c.id !== id))} 
            onResetClusterProgress={handleResetClusterProgress} 
            totalPlanCount={plans.length} 
            clusterProgressData={clusterProgressData} 
          />
        );
      case 'churches':
        if (!selectedCluster) return <div className="text-center p-12 bg-white/60 rounded-3xl shadow-xl max-w-xl mx-auto border border-white"><p className="text-slate-700 font-bold">Selecciona una Zona primero.</p></div>;
        return (
          <ChurchesPanel 
            churches={churches.filter(c => selectedCluster.churchIds.includes(c.id))} 
            selectedChurchId={selectedChurch?.id} 
            onSelectChurch={(c) => setAppState({...appState, churchId: c.id, tab: 'plan'})} 
            onSelectClusterPlan={() => setAppState({...appState, churchId: null, tab: 'plan'})} 
            onAddChurch={(name) => { const id = Date.now(); setChurches([...churches, {id, name}]); setClusters(clusters.map(cl => cl.id === selectedCluster.id ? {...cl, churchIds: [...cl.churchIds, id]} : cl)) }} 
            onDeleteChurch={(id) => setChurches(churches.filter(c => c.id !== id))} 
            onResetChurchProgress={handleResetChurchProgress} 
            onBack={() => setAppState({...appState, tab: 'clusters'})}
            totalPlanCount={plans.length} 
            progressData={churchProgressData} 
          />
        );
      case 'plan':
        if (!selectedChurch && !selectedCluster) return <div className="text-center p-12 bg-white/60 rounded-3xl shadow-xl max-w-xl mx-auto border border-white"><p className="text-slate-700 font-bold">Selecciona una entidad para ver el plan.</p></div>;
        
        const plansByMonth = currentViewPlans.reduce((acc, plan) => {
            const month = Math.ceil(plan.weekNumber / 4);
            if (!acc[month]) acc[month] = [];
            acc[month].push(plan);
            return acc;
        }, {} as Record<number, WeeklyPlan[]>);
        const months = Object.keys(plansByMonth).map(Number).sort((a, b) => a - b);

        if (selectedMonth === null) {
            return (
                <div className="animate-fade-in-up pb-10">
                    <div className="flex justify-start mb-6 max-w-6xl mx-auto px-4">
                        <button 
                            onClick={() => setAppState({...appState, tab: 'churches'})}
                            className="flex items-center gap-2 px-6 py-3 text-sm font-bold text-slate-600 bg-white/80 rounded-full hover:bg-white transition-all border border-slate-200 shadow-sm"
                        >
                            <ArrowLeftIcon className="w-4 h-4" /> 
                            Volver a Iglesias
                        </button>
                    </div>
                    <div className="flex flex-col items-center mb-12">
                        <div className="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-indigo-50/80 backdrop-blur-sm text-indigo-700 text-xs font-bold uppercase tracking-wide mb-3 border border-indigo-100 shadow-sm">
                           {selectedChurch ? `Plan para: ${selectedChurch.name}` : `Capacitación de Zona: ${selectedCluster?.name}`}
                        </div>
                        <h2 className="text-4xl font-black text-slate-900 tracking-tight mb-4">Ruta de Desarrollo</h2>
                        <div className="flex flex-wrap justify-center gap-4">
                            <input type="file" ref={fileInputRef} onChange={handleFileUpload} className="hidden" accept=".txt" />
                            <button 
                                onClick={() => fileInputRef.current?.click()}
                                className="flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-indigo-600 to-blue-700 text-white rounded-2xl font-bold shadow-xl hover:shadow-indigo-500/40 transition-all hover:-translate-y-1 active:scale-95"
                            >
                                <UploadIcon className="w-5 h-5" />
                                Subir Misión y Visión (IA)
                            </button>
                            <button 
                                onClick={handleManualReset}
                                className="flex items-center gap-2 px-6 py-4 bg-white text-slate-600 border border-slate-200 rounded-2xl font-bold shadow-sm hover:bg-slate-50 transition-all active:scale-95"
                            >
                                Reiniciar Plan Maestro
                            </button>
                        </div>
                    </div>

                    <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto px-4">
                        {months.map(month => {
                            const monthPlans = plansByMonth[month];
                            const completedCount = monthPlans.filter(p => p.isCompleted).length;
                            const totalCount = monthPlans.length;
                            const progress = Math.round((completedCount / totalCount) * 100);
                            const moduleTitle = getModuleTitle(monthPlans);

                            return (
                                <div key={month} className="group bg-white/60 backdrop-blur-xl rounded-[2.5rem] p-8 border border-white shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 flex flex-col">
                                    <button onClick={() => setSelectedMonth(month)} className="text-left flex-grow">
                                        <div className="flex justify-between items-start mb-6">
                                            <div className="w-16 h-16 rounded-2xl bg-indigo-600 text-white flex items-center justify-center text-3xl font-black shadow-lg">0{month}</div>
                                            <span className="text-[10px] font-black text-indigo-500 uppercase tracking-widest bg-indigo-50 px-3 py-1 rounded-full">Mes</span>
                                        </div>
                                        <h3 className="text-xl font-bold text-slate-800 leading-tight mb-2">{moduleTitle}</h3>
                                        <p className="text-slate-500 text-sm font-medium">Contiene {totalCount} lecciones clave para tu crecimiento.</p>
                                    </button>
                                    
                                    <div className="mt-8 pt-6 border-t border-slate-100">
                                        <div className="flex justify-between items-center text-xs font-bold text-slate-400 uppercase tracking-tighter mb-2">
                                            <span>Progreso</span>
                                            <span>{progress}%</span>
                                        </div>
                                        <div className="w-full h-2 bg-slate-100 rounded-full overflow-hidden mb-4">
                                            <div className="h-full bg-indigo-500 transition-all duration-1000" style={{ width: `${progress}%` }}></div>
                                        </div>
                                        
                                        {progress === 100 && (
                                            <button 
                                                onClick={(e) => { e.stopPropagation(); generateCertificate(month, monthPlans); }}
                                                className="w-full flex items-center justify-center gap-2 py-3 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl text-xs font-bold shadow-lg shadow-emerald-200 transition-all active:scale-95"
                                            >
                                                <DownloadIcon className="w-4 h-4" />
                                                Descargar Certificado
                                            </button>
                                        )}
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                </div>
            );
        }

        return (
          <div className="animate-fade-in-up pb-12 max-w-7xl mx-auto">
                <div className="flex justify-between items-center mb-10">
                    <button onClick={() => setSelectedMonth(null)} className="flex items-center gap-2 px-6 py-3 text-sm font-bold text-slate-600 bg-white/80 rounded-full hover:bg-white transition-all border border-slate-200 shadow-sm"><ArrowLeftIcon className="w-4 h-4" /> Volver</button>
                    <h2 className="text-3xl font-black text-slate-900">Mes {selectedMonth}</h2>
                </div>
                <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                    {plansByMonth[selectedMonth].map(plan => (<TopicCard key={plan.weekNumber} plan={plan} onToggleComplete={() => handleToggleComplete(plan.weekNumber)} />))}
                </div>
          </div>
        );
      case 'dashboard':
        return <DashboardPanel clusters={clusters} churches={churches} churchProgressData={churchProgressData} clusterProgressData={clusterProgressData} totalPlanCount={plans.length} />;
      case 'progress':
        return <MonitoringPanel plans={currentViewPlans} onTopicSelect={(w) => { setSelectedMonth(Math.ceil(w/4)); setAppState({...appState, tab: 'plan'}) }} onBack={() => setAppState({...appState, tab: 'plan'})} churchName={selectedChurch?.name || selectedCluster?.name || 'General'} />;
      default:
        return null;
    }
  };

  return (
    <div className="min-h-screen text-slate-800 font-sans relative overflow-x-hidden">
      <AnimatedBackground />
      <div className="relative z-10">
        <header className="pt-16 pb-10 text-center">
            <div className="inline-block bg-white/90 backdrop-blur-2xl rounded-[3rem] px-12 py-8 shadow-2xl border border-white/50">
                <h1 className="text-4xl sm:text-6xl font-black tracking-tighter bg-clip-text text-transparent bg-gradient-to-br from-indigo-700 via-blue-600 to-cyan-500">ECOSISTEMA PECES</h1>
                <p className="text-slate-400 font-bold text-xs mt-2 uppercase tracking-[0.3em]">Plataforma de Liderazgo Ministerial v10.0</p>
            </div>
        </header>
        <main className="max-w-screen-2xl mx-auto px-6">
            <nav className="mb-12 flex justify-center">
              <div className="flex gap-1 p-2 bg-white/30 backdrop-blur-xl rounded-full shadow-inner ring-1 ring-white/40">
                {['clusters', 'churches', 'plan', 'progress', 'dashboard'].map((t) => (
                  <button key={t} onClick={() => setAppState({...appState, tab: t as ActiveTab})} className={`py-3 px-8 rounded-full font-bold text-sm transition-all duration-500 ${activeTab === t ? 'bg-indigo-600 text-white shadow-xl scale-105' : 'text-slate-600 hover:bg-white/50'}`}>
                    {t === 'clusters' ? 'Zonas' : t === 'churches' ? 'Iglesias' : t === 'plan' ? 'Estudio' : t === 'progress' ? 'Avance' : 'Reporte'}
                  </button>
                ))}
              </div>
            </nav>
            {renderContent()}
        </main>
      </div>
    </div>
  );
};

export default App;
