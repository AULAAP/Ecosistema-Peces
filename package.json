/* --- PECES --- */

.fish-container {
    position: absolute;
    animation: swim linear infinite;
    /* z-index managed in React for depth */
}

.fish {
    width: 80px;
    height: 40px;
    /* Color defaults managed by specific rules below */
    /* IMPORTANT: Remove any default filter here to ensure sharpness */
    filter: none;
}

/* 
    Group 1: Sharp Fish (Foreground)
    - Drop shadow helps detach them from background.
    - High opacity.
    - No blur.
*/
.fish-sharp {
    animation: fish-pulse 6s infinite ease-in-out alternate;
    opacity: 0.5; /* Reduced from 1 for transparency */
    filter: drop-shadow(0 4px 3px rgba(0,0,0,0.1));
}

/* 
    Group 2: Blurring Fish (Background)
    - Transitions to blur.
    - Slightly lower opacity.
*/
.fish-blurring {
    animation: 
        fish-pulse 5s infinite ease-in-out alternate,
        become-blurry 3s ease-out 2s forwards; /* 2s delay before blurring starts */
}

@keyframes swim {
    from { transform: translateX(calc(100vw + 150px)); }
    to { transform: translateX(-150px); }
}

@keyframes fish-pulse {
    0% { transform: scale(1); }
    100% { transform: scale(1.1); }
}

@keyframes become-blurry {
    0% { 
        filter: blur(0px); 
        opacity: 0.5; 
    }
    100% { 
        filter: blur(3px); 
        opacity: 0.25; 
    }
}

/* Estilos para Generación de PDF */
.is-generating-pdf .custom-scrollbar {
  max-height: none !important;
  overflow: visible !important;
}

.is-generating-pdf {
  background-color: #f1f5f9 !important;
  padding: 20px !important;
}

