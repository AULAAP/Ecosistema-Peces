body {
  background-color: #f1f5f9; /* Tailwind's slate-100 */
  font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
}

/* 
  Water Background
*/
.water-background {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
  background-color: #87CEEB; /* Sky blue */
  background-image: linear-gradient(to top, #1e3a8a 0%, #3b82f6 50%, #bfdbfe 100%);
  filter: blur(8px);
  transform: scale(1.1);
}

/* Cáusticas */
.water-background::before {
  content: '';
  position: absolute;
  top: -100%;
  left: -100%;
  right: -100%;
  bottom: -100%;
  width: 400%;
  height: 400%;
  background-image: 
    radial-gradient(ellipse at center, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 35%),
    radial-gradient(ellipse at 20% 80%, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0) 30%),
    radial-gradient(ellipse at 80% 30%, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 25%),
    radial-gradient(ellipse at 90% 90%, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0) 20%);
  animation: water-ripples 25s linear infinite;
  opacity: 0.6;
}

/* Rayos de sol */
.water-background::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: 
    linear-gradient(to bottom, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0) 80%);
  transform-origin: top center;
  animation: sun-rays 15s ease-in-out infinite alternate;
  pointer-events: none;
  z-index: 0;
}


@keyframes water-ripples {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes sun-rays {
    0% {
        opacity: 0.7;
        transform: scale(1) rotate(-2deg);
    }
    100% {
        opacity: 0.9;
        transform: scale(1.1) rotate(2deg);
    }
}

/* --- Espuma de Mar --- */
.sea-foam {
  position: absolute;
  top: 0;
  left: -5%;
  width: 110%;
  height: 60px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100"><filter id="f"><feTurbulence type="fractalNoise" baseFrequency="0.02 0.01" numOctaves="3" seed="0" /></filter><rect width="100%" height="100%" filter="url(%23f)" /></svg>');
  mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100"><filter id="f"><feTurbulence type="fractalNoise" baseFrequency="0.02 0.01" numOctaves="3" seed="0" /></filter><rect width="100%" height="100%" filter="url(%23f)" /></svg>');
  mask-size: 100% 100%;
  mask-repeat: repeat-x;
  animation: foam-movement 20s linear infinite;
  z-index: 30; /* Ensure foam is on top */
}

@keyframes foam-movement {
  0% { transform: translateX(0); }
  50% { transform: translateX(-5%); }
  100% { transform: translateX(0); }
}


/* --- Burbujas --- */
.bubbles {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: 15; /* Behind sharp fish, in front of background */
}

.bubble {
  position: absolute;
  bottom: -150px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  opacity: 0;
  animation: rise linear infinite;
  border: 1px solid rgba(255, 255, 255, 0.3);
}

@keyframes rise {
  0% { transform: translateY(0); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { transform: translateY(-120vh) translateX(5vw); opacity: 0; }
}

/* Variaciones de Burbujas */
.bubble:nth-child(1) { left: 10%; width: 20px; height: 20px; animation-duration: 10s; animation-delay: 0s; }
