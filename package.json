.bubble:nth-child(5) { left: 65%; width: 25px; height: 25px; animation-duration: 7s; animation-delay: 1s; }
.bubble:nth-child(6) { left: 75%; width: 18px; height: 18px; animation-duration: 9s; animation-delay: 3s; }
